<UserControl x:Class="SegmentEffectPlugin.SegmentEffectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SegmentEffectPlugin"
             MinWidth="280">

    <UserControl.Resources>
        <local:BoolToVisConverter x:Key="BoolToVis"/>

        <!-- カラー -->
        <SolidColorBrush x:Key="BG"      Color="#18181B"/>
        <SolidColorBrush x:Key="CardBG"  Color="#27272A"/>
        <SolidColorBrush x:Key="Border"  Color="#3F3F46"/>
        <SolidColorBrush x:Key="FG"      Color="#FAFAFA"/>
        <SolidColorBrush x:Key="FGSub"   Color="#A1A1AA"/>
        <SolidColorBrush x:Key="Accent"  Color="#3B82F6"/>

        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="Sub" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FGSub}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBG}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- 入力TextBox -->
        <Style x:Key="NumInput" TargetType="TextBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="55"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ボタン -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#3F3F46" BorderBrush="#52525B" BorderThickness="1"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{StaticResource FG}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#52525B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#3B82F6" BorderBrush="#2563EB" BorderThickness="1"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="White" TextBlock.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BG}" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14,10,14,16">

            <!-- ヘッダー -->
            <TextBlock Text="✂  テキスト自動分割ツール" FontSize="17" FontWeight="Bold" Foreground="{StaticResource FG}" Margin="0,0,0,2"/>
            <TextBlock Style="{StaticResource Sub}" Margin="0,0,0,10"
                       Text="テキストアイテムを行・文字数・文字選択で分割し、個別にエフェクトを適用"/>

            <!-- ===== プロジェクト ===== -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="📁 プロジェクト" Style="{StaticResource H2}"/>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="自動検出" Command="{Binding AutoDetectCommand}" Style="{StaticResource Btn}" Margin="4,0,0,0"/>
                            <Button Content="参照..." Command="{Binding BrowseCommand}" Style="{StaticResource Btn}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <TextBox Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"
                                 Background="#18181B" Foreground="{StaticResource FGSub}" BorderBrush="{StaticResource Border}"
                                 Padding="6,4" FontSize="11" VerticalContentAlignment="Center"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ===== テキストアイテム一覧 ===== -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Content="🔍 検索" Command="{Binding ScanCommand}" Style="{StaticResource Btn}" Padding="10,5"/>
                        <StackPanel>
                            <TextBlock Text="💬 テキストアイテム" Style="{StaticResource H2}" Margin="0"/>
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Sub}"/>
                        </StackPanel>
                    </DockPanel>
                    <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" MinHeight="80" MaxHeight="200">
                        <ListBox ItemsSource="{Binding TextItems}" SelectedItem="{Binding SelectedTextItem}"
                                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Foreground="{StaticResource FG}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="Foreground" Value="{StaticResource FG}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" Padding="{TemplateBinding Padding}" Background="Transparent"
                                                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#3F3F46"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#1E3A5F"/>
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding PreviewText}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource FG}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Details}" FontSize="10" Foreground="{StaticResource FGSub}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== 分割設定（選択時のみ表示）===== -->
            <Border Style="{StaticResource Card}" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="⚙ 分割モード" Style="{StaticResource H2}"/>

                    <!-- モード切替 -->
                    <WrapPanel Margin="0,0,0,10">
                        <RadioButton Content="行で分割" IsChecked="{Binding SplitMode, Converter={local:IntToBoolConverter}, ConverterParameter=0}"
                                     GroupName="Mode" Foreground="{StaticResource FG}" Margin="0,0,14,0" FontSize="12"/>
                        <RadioButton Content="文字数で分割" IsChecked="{Binding SplitMode, Converter={local:IntToBoolConverter}, ConverterParameter=1}"
                                     GroupName="Mode" Foreground="{StaticResource FG}" Margin="0,0,14,0" FontSize="12"/>
                        <RadioButton Content="文字を選択して分割" IsChecked="{Binding SplitMode, Converter={local:IntToBoolConverter}, ConverterParameter=2}"
                                     GroupName="Mode" Foreground="{StaticResource FG}" FontSize="12"/>
                    </WrapPanel>

                    <!-- 文字数モードパラメータ -->
                    <StackPanel Visibility="{Binding IsCharCountMode, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource Sub}" Margin="0,0,0,4" Text="分割単位の文字数"/>
                        <DockPanel>
                            <TextBox DockPanel.Dock="Right" Text="{Binding CharCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumInput}" Width="45"/>
                            <Slider Value="{Binding CharCount}" Minimum="1" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- 文字選択モードパラメータ -->
                    <StackPanel Visibility="{Binding IsCharSelectMode, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource Sub}" Margin="0,0,0,4" Text="選択範囲を指定（開始位置と文字数）"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="開始位置" FontSize="10" Foreground="{StaticResource FGSub}" Margin="0,0,0,2"/>
                                <DockPanel>
                                    <TextBox DockPanel.Dock="Right" Text="{Binding SelectionStart, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumInput}" Width="40"/>
                                    <Slider Value="{Binding SelectionStart}" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="文字数" FontSize="10" Foreground="{StaticResource FGSub}" Margin="0,0,0,2"/>
                                <DockPanel>
                                    <TextBox DockPanel.Dock="Right" Text="{Binding SelectionLength, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumInput}" Width="40"/>
                                    <Slider Value="{Binding SelectionLength}" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding SelectionInfo}" FontSize="12" Foreground="#60A5FA" Margin="0,6,0,0" FontWeight="Medium"/>
                    </StackPanel>

                    <!-- 間隔設定 -->
                    <Border Background="#1E293B" CornerRadius="4" Padding="10,8" Margin="0,4,0,0">
                        <StackPanel>
                            <!-- 行間 -->
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="行間 (px)" FontSize="11" Foreground="{StaticResource FGSub}" Width="80" VerticalAlignment="Center"/>
                                <TextBox DockPanel.Dock="Right" Text="{Binding LineSpacing, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumInput}"/>
                                <Slider Value="{Binding LineSpacing}" Minimum="-50" Maximum="200" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="6,0,6,0"/>
                            </DockPanel>

                            <!-- 文字間隔 -->
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="文字間隔 (px)" FontSize="11" Foreground="{StaticResource FGSub}" Width="80" VerticalAlignment="Center"/>
                                <TextBox DockPanel.Dock="Right" Text="{Binding CharSpacing, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumInput}"/>
                                <Slider Value="{Binding CharSpacing}" Minimum="-20" Maximum="100" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="6,0,6,0"/>
                            </DockPanel>

                            <!-- 配置間隔% (行分割のみ) -->
                            <DockPanel Visibility="{Binding IsLineMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="配置倍率 (%)" FontSize="11" Foreground="{StaticResource FGSub}" Width="80" VerticalAlignment="Center"/>
                                <TextBox DockPanel.Dock="Right" Text="{Binding SpacingPercent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumInput}"/>
                                <Slider Value="{Binding SpacingPercent}" Minimum="0" Maximum="300" TickFrequency="1" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="6,0,6,0"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== セグメントプレビュー ===== -->
            <Border Style="{StaticResource Card}" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}">
                        <Run Text="📋 プレビュー（"/>
                        <Run Text="{Binding Segments.Count, Mode=OneWay}"/>
                        <Run Text=" セグメント）"/>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Segments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,4" Margin="0,0,0,3" BorderBrush="#334155" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E293B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRemainder}" Value="True">
                                                    <Setter Property="Background" Value="#1C1917"/>
                                                    <Setter Property="BorderBrush" Value="#78716C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontSize="10" Foreground="{StaticResource FGSub}" VerticalAlignment="Center" Width="50">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding CharCount, StringFormat={}{0}文字}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRemainder}" Value="True">
                                                            <Setter Property="Text" Value="残り"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Preview}" FontSize="12" Foreground="{StaticResource FG}" TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== 実行ボタン ===== -->
            <Button Content="✂  選択したアイテムを分割する" Command="{Binding SplitCommand}"
                    Style="{StaticResource AccentBtn}" IsEnabled="{Binding CanSplit}" HorizontalAlignment="Stretch"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
